# Supabase configuration (required for tenant auth and cloud sync)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Owner PIN code (used to access the owner dashboard, 6 digits recommended)
VITE_OWNER_PIN=123789

# Tenant setup key (used for first-time tenant registration)
# Must match the tenant_setup_key in the global_settings table (default: setup-tenant-2026).
# Owner can change it via the Global Settings page.
VITE_TENANT_SETUP_KEY=setup-tenant-2026
